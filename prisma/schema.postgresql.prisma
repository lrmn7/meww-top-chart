// Prisma schema for PostgreSQL
// To use: rename this file to schema.prisma and set DATABASE_URL to postgresql://...

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TrackSnapshot {
  id           String   @id @default(cuid())
  trackName    String
  artistName   String
  country      String   @default("global")
  rank         Int
  dailyStreams  BigInt
  totalStreams  BigInt?
  createdAt    DateTime @default(now())
  
  @@index([createdAt])
  @@index([trackName, artistName])
  @@index([country])
}

model TrackCurrent {
  id           String   @id @default(cuid())
  trackId      String?  // Spotify ID if matched
  trackName    String
  artistName   String
  country      String   @default("global")
  rank         Int
  previousRank Int?
  rankDelta    Int?     // negative = moved up, positive = moved down
  dailyStreams  BigInt
  totalStreams  BigInt?
  imageUrl     String?
  previewUrl   String?
  spotifyUrl   String?
  lastUpdated  DateTime @default(now()) @updatedAt
  
  @@unique([trackName, artistName, country])
  @@index([rank])
  @@index([trackName, artistName])
  @@index([country])
}
