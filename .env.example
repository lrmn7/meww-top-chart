PORT=
# Spotify Web API Credentials
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Optional: Additional Spotify client credentials for rate limit rotation
# SPOTIFY_CLIENT_ID_2=your_second_client_id
# SPOTIFY_CLIENT_SECRET_2=your_second_client_secret
# SPOTIFY_CLIENT_ID_3=your_third_client_id
# SPOTIFY_CLIENT_SECRET_3=your_third_client_secret
# Database (for production, use a PostgreSQL connection string)
# For local development, SQLite will be used automatically
DATABASE_URL="file:./dev.db"

# Admin secret for manual refresh endpoint
ADMIN_SECRET=your secret

# Countries to scrape (comma-separated country codes, always includes global)
# Available: global,nl,us,gb,id,jp,de,fr,br,mx,kr,in,au,es,it,ca,se,ph,tr,ar
SCRAPE_COUNTRIES=global,nl,us,gb,id,jp,de,fr,br,mx,kr,in,au,es,it,ca,se,ph,tr,ar

# Limit how many top artists and tracks to scrape/display (default: 25)
TOP_ARTISTS_LIMIT=25
TOP_TRACKS_LIMIT=25